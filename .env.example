# Database Configuration
DATABASE_URL=postgresql://user:password@host:port/database

# Smart Contract Configuration
CONTRACT_ADDRESS=
# After deploying the contract, add its address here
# Example: CONTRACT_ADDRESS=0x1234567890abcdef1234567890abcdef12345678

# Deployer Configuration (for contract deployment only)
DEPLOYER_PRIVATE_KEY=
# Your wallet's private key for deploying the contract
